import random

print("*Number Guessing Game*")
num = random.randint(1, 100)

while True:
    n = int(input("Enter a number from 1-100: "))

    if num == n:
        print("You win!!")
        break
    elif num > n:
        print("Guess a greater number.")
    else:
        print("Guess a lower number.")
